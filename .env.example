# ------------------------------------------------------------------------------
# Environment Variables for Airflow + Postgres + dbt + Ingestion Pipeline
#
# This file defines all environment variables required by the Airflow
# orchestration stack, the Postgres metadata database, and the ingestion
# modules. Values here are loaded by docker-compose, Airflow, and dbt.
#
# Notes:
#   - Replace placeholder values before running in production.
#   - Do NOT commit real secrets to version control.
#   - Paths map directly to the Medallion architecture (Bronze/Silver/Gold).
# ------------------------------------------------------------------------------

# API Keys
NBA_API_KEY=your_api_key_here
# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
# Database (Airflow metadata DB)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=airflow
# Paths
BRONZE_PATH=/data/bronze
SILVER_PATH=/data/silver
GOLD_PATH=/data/gold
